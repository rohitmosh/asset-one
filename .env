# Database Configuration
POSTGRES_DB=eams
POSTGRES_USER=eams_admin
POSTGRES_PASSWORD=eams_secure_db_prod_pass_2026

# Backend Database connection string (FastAPI container uses this)
DATABASE_URL=postgresql+psycopg://eams_admin:eams_secure_db_prod_pass_2026@postgres:5432/eams

# Authentication Secrets
JWT_SECRET=eams_prod_jwt_super_secret_key_change_me_before_go_live

# Domain / URLs
FRONTEND_URL=https://localhost
BACKEND_URL=https://localhost/api

# Volume Paths (Use /opt/asset-one/postgres_data for DB and D:\AssetOne\Backups for backups)
# DB_DATA_PATH=/opt/asset-one/postgres_data
BACKUP_PATH=/mnt/d/AssetOne/Backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

