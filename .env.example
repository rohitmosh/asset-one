# Database Configuration
POSTGRES_DB=eams
POSTGRES_USER=eams_user
POSTGRES_PASSWORD=your_strong_db_password_here

# Backend Database connection string (FastAPI container uses this)
# Format: postgresql+psycopg://<user>:<password>@<db_host>:<db_port>/<db_name>
DATABASE_URL=postgresql+psycopg://eams_user:your_strong_db_password_here@postgres:5432/eams

# Authentication Secrets
JWT_SECRET=your_jwt_signing_secret_here

# Domain / URLs (For reference or CORS strict configuration if needed)
FRONTEND_URL=https://eams.company.com
BACKEND_URL=https://eams.company.com/api
